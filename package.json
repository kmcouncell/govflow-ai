{
  "name": "govflow-ai",
  "private": true,
  "version": "0.1.0",
  "description": "Federal Government Workflow AI Assistant — monorepo",
  "scripts": {
    "dev:frontend": "npm run dev --prefix frontend",
    "build:frontend": "npm run build --prefix frontend",
    "lint:frontend": "npm run lint --prefix frontend",
    "test:frontend": "npm run test --prefix frontend",
    "dev:backend": "cd backend && uv run uvicorn govflow_backend.main:app --reload",
    "test:backend": "cd backend && uv run pytest -q"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
