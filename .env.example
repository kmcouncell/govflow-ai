# =============================================================================
# GovFlow AI — root & shared (copy to .env and adjust). No secrets in git.
# =============================================================================

# -----------------------------------------------------------------------------
# Runtime environment (drives YAML suffix and optional .env.{ENV} loading)
# -----------------------------------------------------------------------------
GOVFLOW_ENV=development

# -----------------------------------------------------------------------------
# Paths (all configurable; backend resolves relative to process CWD unless absolute)
# -----------------------------------------------------------------------------
GOVFLOW_CONFIG_DIR=config
GOVFLOW_SAMPLE_DATA_DIR=sample_data
GOVFLOW_LOG_DIR=logs

# -----------------------------------------------------------------------------
# Backend HTTP (FastAPI / Uvicorn)
# -----------------------------------------------------------------------------
GOVFLOW_BACKEND_HOST=0.0.0.0
GOVFLOW_BACKEND_PORT=8000
GOVFLOW_BACKEND_RELOAD=false
GOVFLOW_BACKEND_ROOT_PATH=
GOVFLOW_BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# -----------------------------------------------------------------------------
# Logging (values must match config/logging.<env>.yaml where applicable)
# -----------------------------------------------------------------------------
GOVFLOW_LOG_LEVEL=INFO
GOVFLOW_LOG_JSON=false
GOVFLOW_LOG_UVICORN_ACCESS=false
GOVFLOW_HTTP_ACCESS_LOG_ENABLED=false

# -----------------------------------------------------------------------------
# Correlation / request tracing
# -----------------------------------------------------------------------------
GOVFLOW_CORRELATION_ID_REQUEST_HEADER=X-Correlation-ID
GOVFLOW_CORRELATION_ID_RESPONSE_HEADER=X-Correlation-ID

# -----------------------------------------------------------------------------
# Security (browser + host hardening; all toggles are explicit)
# -----------------------------------------------------------------------------
# Comma-separated hostnames for TrustedHostMiddleware; leave empty to disable.
GOVFLOW_SECURITY_TRUSTED_HOSTS=
GOVFLOW_SECURITY_ENABLE_HSTS=false
GOVFLOW_SECURITY_HSTS_MAX_AGE_SECONDS=0
GOVFLOW_SECURITY_ENABLE_FRAME_OPTIONS=true
GOVFLOW_SECURITY_FRAME_OPTIONS_VALUE=DENY
GOVFLOW_SECURITY_ENABLE_CONTENT_TYPE_OPTIONS=true
GOVFLOW_SECURITY_REFERRER_POLICY=strict-origin-when-cross-origin
# Optional Permissions-Policy header value; leave empty to omit the header.
GOVFLOW_SECURITY_PERMISSIONS_POLICY=

# -----------------------------------------------------------------------------
# Feature flags (optional env overrides; unset = use YAML `features.*_api_enabled`)
# -----------------------------------------------------------------------------
GOVFLOW_FEATURE_RAG_API_ENABLED=
GOVFLOW_FEATURE_GRAPH_API_ENABLED=

# -----------------------------------------------------------------------------
# LLM / integrations (optional until wired; leave blank to degrade gracefully)
# -----------------------------------------------------------------------------
GOVFLOW_OPENAI_API_KEY=
GOVFLOW_OPENAI_BASE_URL=
# When set, overrides `app.llm.default_chat_model` from `config/app.*.yaml` for chat + generative RAG.
GOVFLOW_OPENAI_MODEL=

# -----------------------------------------------------------------------------
# LangGraph / agent (optional)
# -----------------------------------------------------------------------------
GOVFLOW_LANGGRAPH_CHECKPOINT_DIR=
GOVFLOW_LANGGRAPH_THREAD_ID_PREFIX=govflow

# -----------------------------------------------------------------------------
# RAG / vector retrieval (see config/rag.default.yaml for chunking, prompts, loaders)
# -----------------------------------------------------------------------------
GOVFLOW_RAG_VECTOR_BACKEND=chroma
GOVFLOW_RAG_CHROMA_PERSIST_DIRECTORY=./data/chroma
GOVFLOW_RAG_PG_DSN=
GOVFLOW_RAG_COLLECTION_NAME=govflow-default
GOVFLOW_RAG_EMBEDDING_MODEL=text-embedding-3-small
GOVFLOW_RAG_EMBEDDING_DIMENSIONS=1536
GOVFLOW_RAG_USE_FAKE_EMBEDDINGS=false
# Directory scanned by the default markdown_directory loader (see rag.default.yaml).
GOVFLOW_RAG_SOURCE_DIR=sample_data/rag_docs
# Optional single-file loader path (leave empty to skip that loader).
GOVFLOW_RAG_SINGLE_FILE=

# -----------------------------------------------------------------------------
# Frontend (Vite) — only VITE_* are exposed to the browser
# -----------------------------------------------------------------------------
VITE_GOVFLOW_API_BASE_URL=http://localhost:8000
VITE_GOVFLOW_APP_NAME=GovFlow AI
VITE_GOVFLOW_ENV=development
VITE_GOVFLOW_GRAPH_STREAM_PATH=/v1/graph/stream

# Optional UI feature flags (public; "true"/"false")
VITE_GOVFLOW_FEATURE_ASSISTANT=true
VITE_GOVFLOW_FEATURE_WORKFLOW=true

# -----------------------------------------------------------------------------
# Frontend dev server (Vite reads these from the repo root via vite.config.ts)
# -----------------------------------------------------------------------------
FRONTEND_DEV_PORT=5173

# Docker Compose published port for the built SPA image
FRONTEND_HOST_PORT=5173
